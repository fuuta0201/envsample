{
  "name": "envsample",
  "version": "1.0.0",
  "description": "Create a .env.sample file using .env, .env.local and .env.test",
  "license": "MIT",
  "private": true,
  "type": "module",
  "bin": {
    "envsample": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
